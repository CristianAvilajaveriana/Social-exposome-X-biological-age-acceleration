############################################################
# Mediation Analyses
#
# This script performs the primary mediation analyses for
# social exposome measures, epigenetic age acceleration (EAA),
# brain age gap (BAG), and clinical outcomes.
#
# Mediation models are performed in the full sample and within
# diagnostic strata:
#   - Dementia
#   - Control
#   - HC
#   - AD
#   - FTD
#
# Mediation frameworks:
#
#   1. EAA-mediated models
#      Social exposure -> EAA -> clinical outcome
#
#   2. BAG-mediated models
#      Social exposure -> BAG -> clinical outcome
#
# Bootstrap:
#   - 5,000 nonparametric bootstrap resamples
#
# Model specifications:
#
#   Full-sample EAA mediation:
#     Mediator model:
#       EAA ~ social exposure + age + sex + smoking + site + diagnosis
#     Outcome model:
#       clinical outcome ~ social exposure + EAA + age + sex + smoking + site + diagnosis
#
#   Stratified EAA mediation:
#     Mediator model:
#       EAA ~ social exposure + age + sex + smoking + site
#     Outcome model:
#       clinical outcome ~ social exposure + EAA + age + sex + smoking + site
#
#   BAG mediation:
#     Mediator model:
#       BAG ~ social exposure + age + sex + smoking
#     Outcome model:
#       clinical outcome ~ social exposure + BAG + age + sex + smoking
#
# Outputs:
#   - ACME / indirect effect
#   - ADE / direct effect
#   - Total effect
#   - Proportion mediated
#   - 95% bootstrap confidence intervals
#   - p-values
#   - Benjamini-Hochberg FDR
#   - Path a, path b, path c, and path c'
#   - Model-wise sample size
############################################################

# ------------------------------------------------------------
# Packages
# ------------------------------------------------------------

required_packages <- c(
  "readxl",
  "dplyr",
  "tidyr",
  "purrr",
  "broom",
  "tibble",
  "stringr",
  "openxlsx",
  "mediation"
)

missing_packages <- required_packages[
  !required_packages %in% rownames(installed.packages())
]

if (length(missing_packages) > 0) {
  install.packages(missing_packages)
}

library(readxl)
library(dplyr)
library(tidyr)
library(purrr)
library(broom)
library(tibble)
library(stringr)
library(openxlsx)
library(mediation)

# ------------------------------------------------------------
# Project configuration
# ------------------------------------------------------------

project_dir <- "."

input_file <- file.path(
  project_dir,
  "data",
  "analysis_dataset.xlsx"
)

output_dir <- file.path(
  project_dir,
  "results",
  "mediation_analyses"
)

dir.create(output_dir, recursive = TRUE, showWarnings = FALSE)

file_type <- "xlsx"   # options: "xlsx" or "csv"

n_boot <- 5000
set.seed(20260706)

# ------------------------------------------------------------
# Variable definitions
# ------------------------------------------------------------
# Replace only the values on the right if your local dataset uses
# different column names.

# Covariates
var_age       <- "Decimal.Chronological.Age"
var_sex       <- "demo_sex"
var_smoking   <- "demo_smoke"
var_site      <- "demo_resid"
var_diagnosis <- "diagnosiscognormal"
var_clinical  <- "clinical_diagnosis"

# Expected coding:
# var_diagnosis should identify Dementia and Control.
# var_clinical should identify HC/CN, AD, and FTD.
diagnosis_binary_levels <- list(
  Dementia = c("Dementia", "dementia", "Case", "case", "0", 0),
  Control  = c("Control", "control", "CN", "HC", "1", 1)
)

clinical_levels <- list(
  HC  = c("HC", "CN", "Control", "control"),
  AD  = c("AD", "Alzheimer", "Alzheimer disease"),
  FTD = c("FTD", "Frontotemporal dementia")
)

# Social exposome measures
global_social_vars <- c(
  CSRI = "GPRI_reconstructed",
  MSE  = "MSE_global_risk"
)

social_domain_vars <- c(
  Education       = "GPRI_domain_education",
  `Social support` = "GPRI_domain_social_support",
  Adversities    = "GPRI_domain_adversities",
  Socioeconomics = "GPRI_domain_socioeconomic_conditions"
)

social_exposures <- c(
  global_social_vars,
  social_domain_vars
)

# EAA mediators
eaa_mediators <- c(
  PhenoAge        = "EAA_PhenoAge",
  Hannum          = "EAA_Hannum",
  Horvath         = "EAA_Horvath",
  DNAmFitAge      = "EAA_DNAmFitAge",
  Blood           = "EAA_Blood",
  Brain           = "EAA_Brain",
  Heart           = "EAA_Heart",
  Immune          = "EAA_Immune",
  Inflammation    = "EAA_Inflammation",
  Kidney          = "EAA_Kidney",
  Liver           = "EAA_Liver",
  Lung            = "EAA_Lung",
  MusculoSkeletal = "EAA_MusculoSkeletal",
  OMICmAge        = "EAA_OMICmAge",
  Retroclock      = "EAA_Retroclock",
  Hormone         = "EAA_Hormone",
  Metabolic       = "EAA_Metabolic",
  SystemsAge      = "EAA_SystemsAge"
)

# BAG mediators
bag_mediators <- c(
  `Functional BAG` = "BAG_funct",
  `Structural BAG` = "BAG_structural"
)

# Clinical outcomes
clinical_outcomes <- c(
  MMSE           = "mmse_total",
  CDR            = "CDR",
  `T-ADLQ total` = "t_adlq_total_score5"
)

