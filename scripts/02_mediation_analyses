model_info <- tibble(
  Mediator_family = c("EAA", "BAG"),
  Full_sample_covariates = c(
    paste(covars_eaa_full, collapse = " + "),
    paste(covars_bag_full, collapse = " + ")
  ),
  Stratified_covariates = c(
    paste(covars_eaa_stratified, collapse = " + "),
    paste(covars_bag_stratified, collapse = " + ")
  ),
  Bootstrap = paste0(n_boot, " nonparametric bootstrap resamples"),
  FDR = "Benjamini-Hochberg correction applied to ACME p-values within mediator family, stratum, exposure, and outcome; global ACME FDR also provided within mediator family and stratum",
  Paths = "Path a: mediator ~ exposure + covariates; path b and c': outcome ~ exposure + mediator + covariates; path c: outcome ~ exposure + covariates"
)

addWorksheet(wb, "Model_info")
writeData(wb, "Model_info", model_info)
setColWidths(wb, "Model_info", cols = 1:ncol(model_info), widths = "auto")

