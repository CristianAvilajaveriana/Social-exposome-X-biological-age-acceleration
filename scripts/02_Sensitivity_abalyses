############################################################
# Sensitivity Analyses
#
# This script performs sensitivity analyses for the association
# between social exposome measures, epigenetic age acceleration
# (EAA), and brain age gap (BAG).
#
# Analyses included:
#   1. Models excluding diagnosis adjustment
#   2. Sex-stratified analyses
#   3. Clinical subgroup analyses
#   4. Interaction analyses
#   5. Matched sample analyses
#
# Matching analyses use 1:1 nearest-neighbor propensity score
# matching for CN vs AD and CN vs FTD comparisons.
############################################################

# ------------------------------------------------------------
# Packages
# ------------------------------------------------------------

required_packages <- c(
  "readxl", "dplyr", "tidyr", "purrr", "broom", "tibble",
  "stringr", "openxlsx", "writexl", "MatchIt", "cobalt",
  "ggplot2", "svglite", "ragg"
)

missing_packages <- required_packages[
  !required_packages %in% rownames(installed.packages())
]

if (length(missing_packages) > 0) {
  install.packages(missing_packages)
}

library(readxl)
library(dplyr)
library(tidyr)
library(purrr)
library(broom)
library(tibble)
library(stringr)
library(openxlsx)
library(writexl)
library(MatchIt)
library(cobalt)
library(ggplot2)
