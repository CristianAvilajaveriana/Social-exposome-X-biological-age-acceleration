  cat("\nMissing variables:\n")
  print(missing_vars)
  stop("Update the variable definitions at the top of the script.")
}

dat <- dat_raw %>%
  mutate(
    across(all_of(c(unname(all_social_vars), unname(eaa_vars), unname(bag_vars), var_age)), as.numeric),
    across(all_of(c(var_sex, var_smoking, var_site, var_diagnosis, var_clinical)), as.factor),
    Sex_raw = as.character(.data[[var_sex]]),
    Sex = recode(Sex_raw, !!!sex_map, .default = paste0("Sex_", Sex_raw)),
    Sex = factor(Sex),
    Site_raw = as.character(.data[[var_site]]),
    Country = recode(Site_raw, !!!country_map, .default = Site_raw),
    Country = factor(Country),
    Diagnosis_raw = as.character(.data[[var_diagnosis]]),
    Cognitive_status = case_when(
      Diagnosis_raw %in% c("0", "Dementia", "dementia", "Case", "case") ~ "Dementia",
      Diagnosis_raw %in% c("1", "Control", "control", "CN", "HC") ~ "Control",
      TRUE ~ NA_character_
    ),
    Cognitive_status = factor(Cognitive_status, levels = c("Control", "Dementia")),
    Clinical_diagnosis = as.character(.data[[var_clinical]]),
    Clinical_diagnosis = recode(
      Clinical_diagnosis,
      "Control" = "CN",
      "control" = "CN",
      "HC" = "CN",
      .default = Clinical_diagnosis
    ),
    Clinical_diagnosis = factor(Clinical_diagnosis, levels = c("CN", "AD", "FTD"))
  )

if ("Male" %in% levels(dat$Sex)) {
  dat <- dat %>% mutate(Sex = relevel(Sex, ref = "Male"))
}

if ("Colombia" %in% levels(dat$Country)) {
  dat <- dat %>% mutate(Country = relevel(Country, ref = "Colombia"))
}

